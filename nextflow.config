profiles {
    conda {
        conda.enabled    = true
        conda.useMamba   = false
        process.conda    = 'base'
    }
    test {
        params.reads  = "$projectDir/assets/testdata/sample1_{1,2}.fastq.gz"
        params.genome = "$projectDir/assets/testdata/ref.fa"
        params.outdir = "results"
    }
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        process.memory   = '32 GB'
        process.cpus     = 8
        process.time     = '24h'
    }
}

process {
    errorStrategy = 'retry'
    maxRetries    = 2
}

manifest {
    name            = 'nf-germline-varcall'
    description     = 'Germline variant calling pipeline following GATK Best Practices'
    version         = '1.0.0'
    author          = 'Janet'
    nextflowVersion = '>=23.0.0'
}
